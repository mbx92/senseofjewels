// Landing Page CMS — Prisma Schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ Models ============

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin") // "superadmin" | "admin" | "customer"
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("site_settings")
}

model Section {
  id        String      @id @default(cuid())
  slug      String      @unique
  title     String
  subtitle  String?     @db.Text
  body      String?     @db.Text
  image     String?
  sortOrder Int         @default(0)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("sections")
}

model Collection {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  image       String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("collections")
}

model Product {
  id           String      @id @default(cuid())
  name         String
  slug         String      @unique
  description  String?     @db.Text
  price        Decimal     @db.Decimal(15, 2)
  image        String?
  gallery      String[]
  collectionId String
  collection   Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  isFeatured   Boolean     @default(false)
  isActive     Boolean     @default(true)
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("products")
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  content   String   @db.Text
  avatar    String?
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  alt       String?
  folder    String?
  createdAt DateTime @default(now())

  @@map("media")
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  // Shipping details (snapshot at order time)
  shipName    String
  shipEmail   String
  shipPhone   String
  shipAddress String      @db.Text
  shipCity    String
  shipProvince String
  shipPostal  String
  shipNotes   String?     @db.Text
  // Financials (in USD)
  subtotal       Decimal   @db.Decimal(15, 2)
  // Payment
  paymentStatus  String    @default("unpaid")  // unpaid | paid | failed | expired
  paymentMethod  String?
  paymentToken   String?
  paymentUrl     String?   @db.Text
  paidAt         DateTime?
  status         String    @default("pending") // pending | confirmed | processing | shipped | delivered | cancelled
  // Shipping (RajaOngkir)
  shippingCost    Decimal?  @db.Decimal(15, 2)  // IDR
  shippingCourier String?   // e.g. "jne", "jnt"
  shippingService String?   // e.g. "REG", "YES"
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  productImage String?
  price       Decimal @db.Decimal(15, 2)
  qty         Int

  @@map("order_items")
}
